# Required — from RSS.com dashboard (Account → API Access)
RSSCOM_API_KEY=your_api_key_here
RSSCOM_PODCAST_ID=your_podcast_id_here

# Where recorded MP3s land (Finder/Explorer path)
# Example macOS: /Users/you/Recordings
# Example Windows: C:\Users\you\Recordings
RSSCOM_AUDIO_DIR=/path/to/your/recordings

# Optional
RSSCOM_DEFAULT_SEASON=1
RSSCOM_TRANSCRIBE_TIMEOUT=3600
